{
  "name": "tablefixer",
  "version": "2.0.0",
  "description": "Repair inconsistent CALS table morerows geometry in SGML documents",
  "main": "src/tablefixer.js",
  "bin": {
    "tablefixer": "bin/tablefixer.js"
  },
  "scripts": {
    "start": "node bin/tablefixer.js broken.sgml",
    "test": "node --test test/unit/*.test.js && node test/compare-geometry.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:geometry": "node test/compare-geometry.js"
  },
  "engines": {
    "node": ">=14"
  },
  "license": "MIT",
  "author": "Port of Alex Düsel's 2014 tablefixer experiment"
}
